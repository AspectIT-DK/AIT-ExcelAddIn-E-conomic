<Window x:Class="AIT_ExcelAddIn_E_conomic.Views.PreferencesWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:local="clr-namespace:AIT_ExcelAddIn_E_conomic.Views"
             Title="Preferences" Height="400" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="AUTO"/>
            <RowDefinition Height="AUTO"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="AUTO"/>
        </Grid.RowDefinitions>

        <!-- Row Operation Preferences -->
        <GroupBox Grid.Row="0" Grid.Column="0" Margin="2" Header="Row Operation Preferences">
            <StackPanel>
                <DockPanel Margin="2" ToolTip="Reserved for future use">
                    <Label IsEnabled="False">Row Color on Successful Operation</Label>
                    <Rectangle x:Name="RectColorIndicatorSuccess" Height="AUTO" Width="55" DockPanel.Dock="Right" Fill="PaleGreen"></Rectangle>
                    <Button x:Name="BtnChangeColorSuccess" Height="AUTO" Width="55" HorizontalAlignment="Right" DockPanel.Dock="Right" ToolTip="Reserved for future use" Click="BtnChangeColorSuccess_Click">Change</Button>
                </DockPanel>
                <DockPanel Margin="2" ToolTip="Reserved for future use">
                    <Label IsEnabled="False">Row Color on Failed Operation</Label>
                    <Rectangle x:Name="RectColorIndicatorFail" Height="AUTO" Width="55" DockPanel.Dock="Right" Fill="LightPink"></Rectangle>
                    <Button x:Name="BtnChangeColorFail" Height="AUTO" Width="55" DockPanel.Dock="Right" HorizontalAlignment="Right" ToolTip="Reserved for future use" Click="BtnChangeColorFail_Click">Change</Button>
                </DockPanel>
                <DockPanel Margin="2">
                    <Label>Row Color on Invoice Draft added Successfully</Label>
                    <Rectangle x:Name="RectColorIndicatorInvoiceSuccess" Height="AUTO" Width="55" DockPanel.Dock="Right" Fill="PaleGreen"></Rectangle>
                    <Button x:Name="BtnChangeColorInvoiceSuccess" Height="AUTO" Width="55" DockPanel.Dock="Right" HorizontalAlignment="Right" Click="BtnChangeColorInvoiceSuccess_Click">Change</Button>
                </DockPanel>
                <DockPanel Margin="2">
                    <Label>Row Color on Invoice Draft not added</Label>
                    <Rectangle x:Name="RectColorIndicatorInvoiceFail" Height="AUTO" Width="55" DockPanel.Dock="Right" Fill="LightPink"/>
                    <Button x:Name="BtnChangeColorInvoiceFail" Height="AUTO" Width="55" DockPanel.Dock="Right" HorizontalAlignment="Right" Click="BtnChangeColorInvoiceFail_Click">Change</Button>
                </DockPanel>
                <DockPanel Margin="2">
                    <Label>Allow Row Color to change</Label>
                    <CheckBox x:Name="CheckBoxAllowRowsChangeColor" IsChecked="True" VerticalAlignment="Center" HorizontalAlignment="Right" DockPanel.Dock="Right"></CheckBox>
                </DockPanel>
            </StackPanel>
        </GroupBox> 
        <!-- Row Operation Preferences -->

        <!-- Save & Cancel Buttons -->
        <StackPanel Orientation="Horizontal" Grid.Column="1" Grid.Row="3" HorizontalAlignment="Right" Margin="4">
            <Button x:Name="BtnSave" Content="Save" Width="80" Margin="1" IsDefault="True" Click="BtnSave_Click"></Button>
            <Button x:Name="BtnCancel" Content="Cancel" Width="80" Margin="1" IsCancel="True"></Button>
        </StackPanel>
        <!-- Save & Cancel Buttons -->
        
        <!-- Status Bar Bottom -->
        <StatusBar Grid.ColumnSpan="2" Grid.Row="4">
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="TextBlockStatusBar" Margin="1 0 12 1"></TextBlock>
            </StatusBarItem>
        </StatusBar>
        <!-- Status Bar Bottom -->
    </Grid>
</Window>