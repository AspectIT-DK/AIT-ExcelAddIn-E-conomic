<Window x:Class="AIT_ExcelAddIn_E_conomic.Views.APISettingsWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:local="clr-namespace:AIT_ExcelAddIn_E_conomic.Views"
             Title="API Settings" Height="200" Width="500" MinWidth="500" MinHeight="200">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="28"/>
            <RowDefinition Height="28"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="20"/>
        </Grid.RowDefinitions>

        <Label Content="App Secret Token" Grid.Column="0" Grid.Row="0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <TextBox x:Name="TextBoxAPIKey" Grid.Column="1" Grid.Row="0" Grid.ColumnSpan="2" TextWrapping="NoWrap" Margin="2 2 2 2"/>

        <Label Content="Agreement Grant Token" Grid.Column="0" Grid.Row="1" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <TextBox x:Name="TextBoxAgreementKey" Grid.Column="1" Grid.Row="1" Grid.ColumnSpan="2" TextWrapping="NoWrap" Margin="2 2 2 2"/>

        <!-- Save & Cancel Buttons -->
        <StackPanel Orientation="Horizontal" Grid.Column="2" Grid.Row="3" HorizontalAlignment="Right" Margin="4">
            <Button x:Name="BtnTestAPI" Content="Test" Width="80" HorizontalAlignment="Left" Margin="1 0 20 0" Click="BtnTestAPI_Click"/>
            <Button x:Name="BtnSave" Content="Save" Width="80" Margin="1" IsDefault="True" Click="BtnSave_Click"></Button>
            <Button x:Name="BtnCancel" Content="Cancel" Width="80" Margin="1" IsCancel="True" Click="BtnCancel_Click"></Button>
        </StackPanel>

        <StatusBar Grid.ColumnSpan="2" Grid.Row="4">
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="TextBlockStatusBar" Margin="1 0 12 1"></TextBlock>
            </StatusBarItem>
        </StatusBar>

    </Grid>
</Window>